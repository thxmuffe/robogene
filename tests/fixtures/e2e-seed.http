@base = {{$processEnv ROBOGENE_API_BASE}}

### Create a test saga
# @name createSaga
POST {{base}}/api/add-saga
Content-Type: application/json

{
  "name": "Smoke Test Saga",
  "description": "A test saga for E2E runs"
}

### Create a roster for the saga
# @name createRoster
POST {{base}}/api/add-roster
Content-Type: application/json

{
  "name": "Test Roster",
  "description": "A roster for E2E runs"
}

### Seed one chapter for the created saga and roster
# @name createChapter
POST {{base}}/api/add-chapter
Content-Type: application/json

{
  "sagaId": "{{createSaga.saga.sagaId}}",
  "rosterId": "{{createRoster.rosterEntity.characterId}}",
  "name": "Smoke Chapter",
  "description": "A deterministic chapter for local E2E runs."
}

### Seed a second frame for the created chapter
POST {{base}}/api/add-frame
Content-Type: application/json

{
  "chapterId": "{{createChapter.chapter.chapterId}}"
}
